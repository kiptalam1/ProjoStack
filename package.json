{
	"private": true,
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"prisma:generate": "prisma generate --schema=apps/server/prisma/schema.prisma",
		"prisma:migrate:dev": "prisma migrate dev --schema=apps/server/prisma/schema.prisma",
		"prisma:migrate:deploy": "prisma migrate deploy --schema=apps/server/prisma/schema.prisma",
		"build": "npm run build --workspace=@projo/contracts && npm run build --workspace=server"
	}
}